# Server
PORT=3002
NODE_ENV=development

# PostgreSQL — running on this server
DATABASE_URL=postgresql://afribit:CHANGE_ME@localhost:5432/afribit_sats

# OpenRouter
OPENROUTER_API_KEY=sk-or-v1-CHANGE_ME
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1

# OpenRouter model routing
# Using the cheapest tier (DeepSeek V3) for all routes to minimise cost.
# Fast/cheap model for simple balance queries and intent classification
OR_MODEL_FAST=deepseek/deepseek-chat
# Mid-tier for standard AI replies
OR_MODEL_MID=deepseek/deepseek-chat
# Heavy model for complex financial analytics
OR_MODEL_HEAVY=deepseek/deepseek-chat

# JWT secret for session tokens
JWT_SECRET=CHANGE_ME_use_openssl_rand_hex_64

# CoinGecko (optional demo key for higher rate limits)
COINGECKO_API_KEY=
COINGECKO_DEMO_KEY=

# Blink wallet integration
# BLINK_API_KEY is used server-side if you want the backend to sync Blink wallets
BLINK_API_KEY=
# BLINK_WEBHOOK_SECRET is required to receive real-time Blink transaction webhooks
# Get this from the Blink dashboard under Webhook settings (whsec_ prefixed)
BLINK_WEBHOOK_SECRET=

# ExchangeRate-API (free, no key required — used to convert BTC/USD to BTC/KES)
EXCHANGE_RATE_API_URL=https://open.er-api.com/v6/latest/USD

# Rate limits
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100
AI_RATE_LIMIT_WINDOW_MS=300000
AI_RATE_LIMIT_MAX=20

# CORS — set to your Vercel frontend URL in production
CORS_ORIGIN=http://localhost:5173
